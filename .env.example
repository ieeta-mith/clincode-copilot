# ClinCode Copilot Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================
# Backend Configuration (FastAPI)
# ============================================
# All backend variables are prefixed with CLINCODE_

# Device for model inference: "cpu" or "cuda"
CLINCODE_DEVICE=cpu

# Path to models directory (inside container)
CLINCODE_MODEL_DIR=/code/models

# Path to ICD dictionary JSON file
CLINCODE_ICD_DICTIONARY_PATH=/code/models/icd_dictionary.json

# Maximum number of text chunks to process per prediction
CLINCODE_MAX_CHUNKS=20

# Maximum tokens per chunk
CLINCODE_MAX_LENGTH=128

# Token overlap between consecutive chunks
CLINCODE_CHUNK_OVERLAP=32

# Number of similar patients to return in neighbor search
CLINCODE_NEIGHBOR_COUNT=50

# Minimum frequency filter default value
CLINCODE_DEFAULT_MIN_FREQ=0

# CORS allowed origins (JSON array format)
CLINCODE_CORS_ORIGINS=["http://localhost:3000", "http://mednat.ieeta.pt:8051"]

# ============================================
# Frontend Configuration (Next.js)
# ============================================

# API URL for client-side requests
# In production with docker-compose, use the service name
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Docker Compose Configuration
# ============================================

# Override default ports if needed
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
